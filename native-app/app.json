{
  "expo": {
    "name": "KameraTakip",
    "slug": "kamera-takip",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#111111"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#111111"
      },
      "permissions": [
        "CAMERA",
        "INTERNET",
        "VIBRATE",
        "ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.kameratakip.app"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Kişi algılama için kamera izni gerekli"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "2415df1f-4aee-48c5-acf5-bf7e43b17988"
      }
    },
    "owner": "selimakclk"
  }
}
